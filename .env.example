# SMTP-Zugangsdaten für das Kontaktformular.
# Bei All-Inkl findest du die Werte in KAS → Post → E-Mail-Adresse.

# Host, z. B. w013dae9.kasserver.com
SMTP_HOST=

# Port: 465 (SSL) empfohlen, alternativ 587 (STARTTLS)
SMTP_PORT=465

# Bei 465 = true, bei 587 = false. Wenn leer, wird automatisch anhand des Ports gewählt.
SMTP_SECURE=true

# Vollständige E-Mail-Adresse, z. B. kontakt@fusspflege-janina.de
SMTP_USER=

# Passwort der Mailbox (nicht das KAS-Login)
SMTP_PASSWORD=

# Absender, muss eine Adresse deiner Domain sein
# Beispiel: "Janinas Fußpflege <kontakt@fusspflege-janina.de>"
CONTACT_FROM=

# Ziel-Adresse für eingehende Nachrichten. Fällt sonst auf site.email zurück.
CONTACT_TO=
